<?xml version="1.0" encoding="utf-8"?>
<!-- Selector stato pressed/selected per bliss_symbol_chip -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Stato premuto -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/l_backgroundDarker" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Stato selezionato -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/l_colorPrimary" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/l_colorPrimaryDark" />
        </shape>
    </item>

    <!-- Stato default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
